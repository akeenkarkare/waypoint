# ---- Waypoint backend config ----
# Copy this file to `.env` and fill in your key.

# REQUIRED. Your Anthropic API key. Powers Cognee's graph extraction (cognify),
# graph Q&A, photo auto-captioning, and story generation — all on Claude Haiku
# (cheapest model: $1 / $5 per 1M tokens).
ANTHROPIC_API_KEY=sk-ant-...

# Model used for all LLM work. Haiku keeps hackathon costs minimal.
LLM_MODEL=claude-haiku-4-5

# Embeddings run LOCALLY and FREE via fastembed (a small ONNX model, no API
# calls). Nothing to configure — the model downloads on first use.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Where uploaded photos are stored (local dev). Object storage comes later.
MEDIA_DIR=./data/media
